generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  professional
  admin
}

enum Language {
  uz
  ru
}

enum OrderStatus {
  awaiting_payment
  pending
  accepted
  on_the_way
  in_progress
  completed
  cancelled
}

enum PaymentProvider {
  payme
  click
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

model User {
  id                String   @id @default(uuid())
  phone             String   @unique
  passwordHash      String?  @map("password_hash")
  name              String?
  role              UserRole @default(customer)
  isVerified        Boolean  @default(false) @map("is_verified")
  avatarUrl         String?  @map("avatar_url")
  language          Language @default(uz)
  telegramChatId    String?  @map("telegram_chat_id")
  telegramLinkToken String?  @map("telegram_link_token")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  masterProfile      MasterProfile?
  clientOrders       Order[]            @relation("ClientOrders")
  masterOrders       Order[]            @relation("MasterOrders")
  sentMessages       Message[]
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]

  @@index([telegramLinkToken])
  @@map("users")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

model MasterProfile {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  bio               String?
  experienceYears   Int      @default(0) @map("experience_years")
  serviceCategoryIds String[] @map("service_category_ids")
  priceMin          Int      @default(0) @map("price_min")
  priceMax          Int      @default(0) @map("price_max")
  ratingAvg         Decimal  @default(0) @map("rating_avg") @db.Decimal(3, 2)
  reviewCount       Int      @default(0) @map("review_count")
  completedOrders   Int      @default(0) @map("completed_orders")
  district          String?
  isApproved        Boolean  @default(true) @map("is_approved")
  isPremium         Boolean  @default(false) @map("is_premium")
  portfolioImages   String[] @map("portfolio_images")
  telegramChatId    String?  @map("telegram_chat_id")
  telegramLinkToken String?  @unique @map("telegram_link_token")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("master_profiles")
}

model Service {
  id          String  @id @default(uuid())
  nameUz      String  @map("name_uz")
  nameRu      String  @map("name_ru")
  icon        String?
  category    String?
  description String?
  isActive    Boolean @default(true) @map("is_active")

  orders Order[]

  @@map("services")
}

model Order {
  id           String      @id @default(uuid())
  clientId     String      @map("client_id")
  masterId     String?     @map("master_id")
  serviceId    String      @map("service_id")
  status       OrderStatus @default(pending)
  description  String?
  address      String?
  latitude     Decimal?    @db.Decimal(10, 8)
  longitude    Decimal?    @db.Decimal(11, 8)
  scheduledAt  DateTime?   @map("scheduled_at")
  price        Int         @default(0)
  isExpress    Boolean     @default(false) @map("is_express")
  expressFee   Int         @default(0) @map("express_fee")
  images       String[]
  cancelReason String?     @map("cancel_reason")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  client   User     @relation("ClientOrders", fields: [clientId], references: [id], onDelete: Cascade)
  master   User?    @relation("MasterOrders", fields: [masterId], references: [id], onDelete: SetNull)
  service  Service  @relation(fields: [serviceId], references: [id])
  review   Review?
  payment  Payment?
  messages Message[]

  @@map("orders")
}

model Review {
  id        String   @id @default(uuid())
  orderId   String   @unique @map("order_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Payment {
  id            String          @id @default(uuid())
  orderId       String          @unique @map("order_id")
  amount        Int
  commission    Int             @default(0)
  provider      PaymentProvider
  status        PaymentStatus   @default(pending)
  transactionId String?         @map("transaction_id")
  createdAt     DateTime        @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Message {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  senderId  String   @map("sender_id")
  text      String?
  imageUrl  String?  @map("image_url")
  isRead    Boolean  @default(false) @map("is_read")
  sentAt    DateTime @default(now()) @map("sent_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([orderId, sentAt])
  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone])
  @@map("otp_codes")
}
